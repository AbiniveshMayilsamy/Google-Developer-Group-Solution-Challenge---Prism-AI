# Prism AI Backend — Environment Configuration
# Copy this file to .env and fill in your values

# Google Gemini API Key (required for AI features)
# Get yours at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB Connection String (required)
# Local:  mongodb://127.0.0.1:27017/prism_ai
# Atlas:  mongodb+srv://username:password@cluster.mongodb.net/prism_ai
MONGO_URI=mongodb://127.0.0.1:27017/prism_ai

# JWT Secret for authentication tokens (required — use a strong random string)
JWT_SECRET=your_jwt_secret_here
