# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5001

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/prism_ai

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ─── Google OAuth (required for Google Sign-In token verification) ─────────────
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ─── AI Providers (tried in this order: Gemini → HuggingFace → OpenAI → Claude)
# At least one must be set. The system auto-falls-back if a provider fails.

# 1. Google Gemini (PRIMARY — recommended for GDG Solution Challenge)
GEMINI_API_KEY=your_gemini_api_key_here

# 2. HuggingFace Inference API (first fallback)
#    Get free key: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# 3. OpenAI (second fallback)
#    Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# 4. Anthropic Claude (third fallback)
#    Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Google Cloud Platform ────────────────────────────────────────────────────
# Required for BigQuery, Pub/Sub, Cloud Run, Vertex AI, Cloud Storage, Cloud Logging
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_REGION=asia-south1

# ─── Google Workspace Integrations ────────────────────────────────────────────
# Used for Sheets import, Calendar events, Tasks, Gmail summaries, Slides generation
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ─── Google Drive / Admin SDK ─────────────────────────────────────────────────
# Service account with domain-wide delegation for Drive, Admin SDK Directory API
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account-key.json
GOOGLE_SERVICE_ACCOUNT_EMAIL=prism-sa@your-domain.com
GOOGLE_WORKSPACE_DOMAIN=your-domain.com
GOOGLE_WORKSPACE_ADMIN_EMAIL=admin@your-domain.com

# ─── BigQuery ─────────────────────────────────────────────────────────────────
BIGQUERY_DATASET=prism_audits

# ─── Pub/Sub ──────────────────────────────────────────────────────────────────
PUBSUB_TOPIC=prism-bias-events

# ─── Cloud Run ────────────────────────────────────────────────────────────────
CLOUD_RUN_SERVICE=prism-api

# ─── Cloud Storage ────────────────────────────────────────────────────────────
GCS_BUCKET=prism-audit-bundles

# ─── Google Chat Webhook ──────────────────────────────────────────────────────
# Create a webhook in your Google Chat space → Apps & Integrations → Webhooks
GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/your-space/messages?key=your-key

# ─── Google Slides ──────────────────────────────────────────────────────────────
GOOGLE_SLIDES_TEMPLATE_ID=YOUR_TEMPLATE_ID

# ─── Google Maps ──────────────────────────────────────────────────────────────
# Browser-restricted API key — set in frontend/.env as VITE_GOOGLE_MAPS_API_KEY
# Optional backend copy for health checks:
GOOGLE_MAPS_API_KEY=your_maps_api_key_here